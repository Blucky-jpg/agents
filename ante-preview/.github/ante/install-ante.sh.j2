#!/bin/bash

apt-get update
apt-get install -y curl jq

# Install ante from GitHub releases
REPO="AntigmaLabs/ante-preview"

{% if version %}
VERSION="{{ version }}"
{% else %}
VERSION="main"
{% endif %}

AUTH_HEADER="Authorization: token {{ GITHUB_TOKEN }}"
ASSET_NAME="ante-${VERSION}-linux-x86_64-musl.tar.gz"

echo "Installing ante version: $VERSION"

# Get release asset info
RELEASE_INFO=$(curl -s -H "$AUTH_HEADER" "https://api.github.com/repos/${REPO}/releases/tags/${VERSION}")
ASSET_ID=$(echo "$RELEASE_INFO" | jq -r ".assets[] | select(.name == \"${ASSET_NAME}\") | .id")

if [ -z "$ASSET_ID" ] || [ "$ASSET_ID" = "null" ]; then
  echo "Could not find release asset: $ASSET_NAME"
  echo "Release info: $RELEASE_INFO"
  exit 1
fi

echo "Downloading asset: $ASSET_NAME (ID: $ASSET_ID)"

# Download and extract
TEMP_DIR=$(mktemp -d)
cd "$TEMP_DIR"

curl -L -H "$AUTH_HEADER" -H "Accept: application/octet-stream" \
  "https://api.github.com/repos/${REPO}/releases/assets/${ASSET_ID}" \
  -o ante.tar.gz

tar -xzf ante.tar.gz

# Install the linux binary
cp ante /usr/local/bin/ante
chmod +x /usr/local/bin/ante

# Cleanup
cd /
rm -rf "$TEMP_DIR"

# Verify installation
ante --version || echo "ante installed"
